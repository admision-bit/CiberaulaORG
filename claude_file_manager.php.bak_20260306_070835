/**
 * Registrar operación en log
 */
function fm_log($action, $details = []) {
    $entry = [
        'timestamp' => date('Y-m-d H:i:s'),
        'ip'        => fm_get_ip(),
        'action'    => $action,
        'details'   => $details,
    ];

    $log_file = FM_LOG_DIR . '/fm_' . date('Y-m-d') . '.log';
    @file_put_contents(
        $log_file,
        json_encode($entry, JSON_UNESCAPED_UNICODE) . "\n",
        FILE_APPEND | LOCK_EX
    );
}

/**
 * Enviar respuesta JSON y terminar
 */
function fm_response($ok, $message, $data = null, $http_code = 200) {
    http_response_code($http_code);
    $response = [
        'ok'      => $ok,
        'message' => $message,
    ];
    if ($data !== null) {
        $response['data'] = $data;
    }
    echo json_encode($response, JSON_UNESCAPED_UNICODE | JSON_PRETTY_PRINT);
    exit;
}

/**
 * Crear backup de un archivo antes de modificarlo
 * Retorna la ruta del backup o false si falla
 */
function fm_create_backup($filepath) {
    if (!file_exists($filepath)) {
        return null; // No hay nada que respaldar
    }

    $dir = dirname($filepath);
    $backup_dir = $dir . '/' . FM_BACKUP_DIR;

    if (!is_dir($backup_dir)) {
        @mkdir($backup_dir, 0755, true);
        // Proteger backups de acceso web
        @file_put_contents($backup_dir . '/.htaccess', "Deny from all\n");
    }

    $basename = basename($filepath);
    $timestamp = date('Ymd_His');
    $backup_name = $basename . '.' . $timestamp . '.bak';
    $backup_path = $backup_dir . '/' . $backup_name;

    if (copy($filepath, $backup_path)) {
        return $backup_path;
    }

    return false;
}

/**
 * Obtener información de un archivo/directorio
 */
function fm_file_info($path) {
    $info = [
        'name'     => basename($path),
        'path'     => $path,
        'exists'   => file_exists($path),
    ];

    if ($info['exists']) {
        $info['is_dir']    = is_dir($path);
        $info['is_file']   = is_file($path);
        $info['size']      = is_file($path) ? filesize($path) : null;
        $info['modified']  = date('Y-m-d H:i:s', filemtime($path));
        $info['perms']     = substr(sprintf('%o', fileperms($path)), -4);
        $info['readable']  = is_readable($path);
        $info['writable']  = is_writable($path);

        if (is_file($path)) {
            $info['extension'] = strtolower(pathinfo($path, PATHINFO_EXTENSION));
            $info['lines']     = (fm_validate_extension($path)) ? count(file($path)) : null;
        }
    }

    return $info;
}

