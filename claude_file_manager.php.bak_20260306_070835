/**
 * Obtener IP del cliente
 */
function fm_get_ip() {
    if (!empty($_SERVER['HTTP_X_FORWARDED_FOR'])) {
        $ips = explode(',', $_SERVER['HTTP_X_FORWARDED_FOR']);
        return trim($ips[0]);
    }
    return $_SERVER['REMOTE_ADDR'] ?? '0.0.0.0';
}

/**
 * Verificar autenticación por token
 */
function fm_authenticate() {
    // Buscar token en header X-FM-Key o en parámetro POST
    $token = $_SERVER['HTTP_X_FM_KEY'] ?? '';
    if (empty($token)) {
        $token = $_POST['_token'] ?? '';
    }
    if (empty($token)) {
        // También aceptar en el body JSON
        $input = json_decode(file_get_contents('php://input'), true);
        $token = $input['_token'] ?? '';
    }

    if (!hash_equals(FM_AUTH_TOKEN, $token)) {
        fm_log('AUTH_FAIL', ['ip' => fm_get_ip()]);
        fm_response(false, 'Autenticación fallida', null, 403);
    }
}

/**
 * Rate limiting por IP usando archivos temporales
 */
function fm_rate_limit() {
    $ip = fm_get_ip();
    $ip_hash = md5($ip);
    $rate_file = FM_LOG_DIR . '/rate_' . $ip_hash . '.json';

    $now = time();
    $requests = [];

    if (file_exists($rate_file)) {
        $data = json_decode(file_get_contents($rate_file), true);
        if (is_array($data)) {
            // Filtrar solo requests dentro de la ventana
            foreach ($data as $ts) {
                if ($now - $ts < FM_RATE_LIMIT_WINDOW) {
                    $requests[] = $ts;
                }
            }
        }
    }

    if (count($requests) >= FM_RATE_LIMIT_MAX) {
        fm_log('RATE_LIMIT', ['ip' => $ip, 'count' => count($requests)]);
        fm_response(false, 'Rate limit excedido. Máximo ' . FM_RATE_LIMIT_MAX . ' peticiones por minuto.', null, 429);
    }

    $requests[] = $now;
    file_put_contents($rate_file, json_encode($requests), LOCK_EX);
}

/**
 * Validar que una ruta está dentro de los directorios permitidos
 * Previene path traversal
 */
function fm_validate_path($path) {
    // Resolver la ruta real (sin ../ ni ./ ni symlinks)
    $real = realpath($path);

    // Si el archivo no existe aún (write/mkdir), resolver el directorio padre
    if ($real === false) {
        $parent = realpath(dirname($path));
        if ($parent === false) {
            return false;
        }
        $real = $parent . '/' . basename($path);
    }

    // Verificar que está dentro de algún directorio permitido
    foreach (FM_ALLOWED_ROOTS as $root) {
        if (strpos($real, $root) === 0) {
            return $real;
        }
    }

    return false;
}

/**
 * Validar extensión de archivo
 * $mode: 'text' (defecto), 'read_all' (incluye imágenes), 'write_binary' (incluye binarios)
 */
function fm_validate_extension($path, $mode = 'text') {
    $ext = strtolower(pathinfo($path, PATHINFO_EXTENSION));

    // .htaccess es un caso especial (no tiene extensión normal)
    $basename = basename($path);
    if ($basename === '.htaccess') {
        return true;
    }

    // Compatibilidad: $mode = true equivale a 'read_all' (versión anterior)
    if ($mode === true) {
        $mode = 'read_all';
    }

    switch ($mode) {
        case 'write_binary':
            // Permite texto + binarios (para escritura con encoding base64)
            $allowed = array_merge(FM_ALLOWED_EXTENSIONS, FM_BINARY_EXTENSIONS);
            return in_array($ext, $allowed);

        case 'read_all':
            // Permite texto + imágenes (para lectura)
            $allowed = array_merge(FM_ALLOWED_EXTENSIONS, FM_IMAGE_EXTENSIONS);
            return in_array($ext, $allowed);

        case 'text':
        default:
            return in_array($ext, FM_ALLOWED_EXTENSIONS);
    }
}

