// Solo aceptar POST
if ($_SERVER['REQUEST_METHOD'] !== 'POST') {
    // GET muestra solo un mensaje informativo
    if ($_SERVER['REQUEST_METHOD'] === 'GET') {
        fm_response(true, 'Claude File Manager v1.1 — Activo. Usar POST con autenticación.', [
            'status'  => 'active',
            'version' => '1.1',
            'method'  => 'POST required',
        ]);
    }
    fm_response(false, 'Método no permitido. Usar POST.', null, 405);
}

// Autenticación
fm_authenticate();

// Rate limiting
fm_rate_limit();

// Leer body JSON
$raw_body = file_get_contents('php://input');
$params = json_decode($raw_body, true);

if (!is_array($params)) {
    fm_response(false, 'Body JSON inválido o vacío');
}

$action = $params['action'] ?? '';

// Despachar acción
switch ($action) {
    case 'info':
        fm_action_info();
        break;

    case 'list':
        fm_action_list($params);
        break;

    case 'read':
        fm_action_read($params);
        break;

    case 'write':
        fm_action_write($params);
        break;

    case 'mkdir':
        fm_action_mkdir($params);
        break;

    case 'delete':
        fm_action_delete($params);
        break;

    case 'rename':
        fm_action_rename($params);
        break;

    case 'search':
        fm_action_search($params);
        break;

    case 'diff':
        fm_action_diff($params);
        break;

    case 'backup':
        fm_action_backup($params);
        break;

    default:
        fm_response(false, 'Acción desconocida: "' . $action . '". Acciones válidas: info, list, read, write, mkdir, delete, rename, search, diff, backup');
}

