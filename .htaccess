# .htaccess ciberaula.org - Moodle 4.5
# v5 - 4 marzo 2026 - guest access activo + enrol/index.php redirige a URL amigable

Options +FollowSymLinks
RewriteEngine On

# SECCION 3B: URL fea -> URL amigable (301)
# Solo actua en peticion directa al servidor, no en reescrituras internas

# 3B ENROL: enrol/index.php?id=X -> curso_redirect.php?id=X (red de seguridad)
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteCond %{QUERY_STRING} ^id=([0-9]+)(&.*)?$
RewriteRule ^enrol\/index\.php$ /curso_redirect.php?id=%1 [R=302,L]

# 3B CURSOS: course/view.php?id=X -> /curso-bonificado-de-[shortname]
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteCond %{QUERY_STRING} ^id=([0-9]+)(&.*)?$
RewriteRule ^course\/view\.php$ /curso_redirect.php?id=%1 [R=302,L]

# 3B CATEGORIAS: course/index.php?categoryid=X -> URL amigable
RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteCond %{QUERY_STRING} ^categoryid=3(&.*)?$
RewriteCond %{QUERY_STRING} !page=
RewriteRule ^course\/index\.php$ \/cursos-bonificados-de-ofimatica? [R=301,L]

