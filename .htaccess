# ROUTER MOVIL CURSOS: curso-bonificado-de-[slug] + UA movil -> /m/curso.php?slug=[slug]
RewriteCond %{REQUEST_URI} !^\/m\/
RewriteCond %{HTTP_USER_AGENT} "Android|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini|Mobile|mobile|CriOS" [NC]
RewriteRule ^curso-bonificado-de-([a-z0-9-]+)\/?$ /m/curso.php?slug=$1 [L,QSA]

# SECCION 3A: URL amigable -> Moodle interno (reescritura, no redirect)

# 3A CURSOS DESKTOP: curso-bonificado-de-[slug] -> course/view.php?name=[slug]
RewriteRule ^curso-bonificado-de-([a-z0-9-]+)\/?$ course\/view.php?name=$1 [L,QSA]

